#include<stdio.h>
#include<conio.h>
main()
{       int x;
	clrscr();
	printf("enter the number=");
	scanf("%d",&x);
	switch(x)
	{
		case 1:
			printf("ONE");
			break;
		case 2:
			printf("TWO");
			break;
		case 3:
			printf("THREE");
			break;
		case 4:
			printf("FOUR");
			break;
		case 5:
			printf("FIVE");
			break;
		default:
			printf("invalid choice..!");
	}

	getch();
	return 0;

}